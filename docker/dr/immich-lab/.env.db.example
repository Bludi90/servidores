# Copia este fichero a .env.db y rellena los secretos reales.
# Puede generarse desde main1 con:
#   sudo docker inspect immich_postgres --format '{{range .Config.Env}}{{println .}}{{end}}' \
#     | grep -E '^(POSTGRES_PASSWORD|POSTGRES_USER|POSTGRES_DB|POSTGRES_INITDB_ARGS|DB_STORAGE_TYPE)='

POSTGRES_PASSWORD=REEMPLAZAR
POSTGRES_USER=postgres
POSTGRES_DB=immich
POSTGRES_INITDB_ARGS=--data-checksums
DB_STORAGE_TYPE=SSD
