# Copia este fichero a .env y ajusta las rutas al snapshot/restore concreto.
# Este lab cubre la fase 1 de DR de Immich:
# - postgres real
# - redis
# - immich-server
# - uploads reales
# No incluye immich-machine-learning en esta primera validación.

IMMICH_BIND_IP=127.0.0.1
IMMICH_BIND_PORT=12283

IMMICH_SERVER_IMAGE=ghcr.io/immich-app/immich-server:v2
IMMICH_DB_IMAGE=ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0@sha256:bcf63357191b76a916ae5eb93464d65c07511da41e3bf7a8416db519b40b1c23
IMMICH_REDIS_IMAGE=docker.io/valkey/valkey:8@sha256:81db6d39e1bba3b3ff32bd3a1b19a6d69690f94a3954ec131277b9a26b95b3aa

IMMICH_SERVER_CONTAINER_NAME=immich-server-lab
IMMICH_DB_CONTAINER_NAME=immich-postgres-lab
IMMICH_REDIS_CONTAINER_NAME=immich-redis-lab

IMMICH_DB_PATH=/mnt/dr-lab-nextcloud-root-replica-20260410-033003/services/immich/postgres
IMMICH_UPLOADS_PATH=/mnt/dr-lab-nextcloud-media-replica-20260410-033003/C_critico/Immich
