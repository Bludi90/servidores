# Copia este fichero a .env.server y rellena/ajusta los valores reales.
# Puede generarse desde main1 con:
#   sudo docker inspect immich_server --format '{{range .Config.Env}}{{println .}}{{end}}' \
#     | grep -E '^(UPLOAD_LOCATION|DB_USERNAME|DB_PASSWORD|DB_DATABASE_NAME|TZ|IMMICH_VERSION)='

DB_USERNAME=postgres
DB_PASSWORD=REEMPLAZAR
DB_DATABASE_NAME=immich
UPLOAD_LOCATION=/srv/storage/media/C_critico/Immich
TZ=Europe/Madrid
IMMICH_VERSION=v2
