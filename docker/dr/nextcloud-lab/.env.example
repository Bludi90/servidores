# Copia este fichero a .env y ajusta las rutas al snapshot/restore concreto.
# Dependencia crítica: este lab necesita /srv/storage dentro del contenedor
# porque Nextcloud usa files_external con rutas locales del host.

TZ=Europe/Madrid

NEXTCLOUD_APP_IMAGE=linuxserver/nextcloud:32.0.1
NEXTCLOUD_DB_IMAGE=linuxserver/mariadb:11.4.5

NEXTCLOUD_APP_CONTAINER_NAME=nextcloud-lab
NEXTCLOUD_DB_CONTAINER_NAME=mariadb-lab

NEXTCLOUD_BIND_IP=127.0.0.1
NEXTCLOUD_BIND_PORT=11443

NEXTCLOUD_APP_PUID=33
NEXTCLOUD_APP_PGID=33
PHP_INI_SCAN_DIR=:/config/php

NEXTCLOUD_CONFIG_PATH=/mnt/dr-lab-nextcloud-config-replica-20260410-033003
NEXTCLOUD_DATA_PATH=/mnt/dr-lab-nextcloud-data-replica-20260410-033003
NEXTCLOUD_DB_PATH=/mnt/dr-lab-nextcloud-db-replica-20260410-033003
NEXTCLOUD_STORAGE_ROOT_PATH=/mnt/dr-lab-nextcloud-root-replica-20260410-033003
NEXTCLOUD_MEDIA_PATH=/mnt/dr-lab-nextcloud-media-replica-20260410-033003
