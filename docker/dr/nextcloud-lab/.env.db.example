# Copia este fichero a .env.db y rellena los secretos reales.
# Puede generarse desde main1 con:
#   sudo docker inspect mariadb --format '{{range .Config.Env}}{{println .}}{{end}}' \
#     | grep -E '^(MYSQL_DATABASE|MYSQL_USER|MYSQL_PASSWORD|MYSQL_ROOT_PASSWORD|PUID|PGID|TZ)='

MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=REEMPLAZAR
MYSQL_ROOT_PASSWORD=REEMPLAZAR
PUID=1000
PGID=1000
TZ=Europe/Madrid
