# Copia este fichero a .env y ajusta las rutas al snapshot/restore concreto.
# El patrón validado en backup1 fue:
# - root clone  -> servicios Jellyfin (config + custom-cont-init.d)
# - media clone -> biblioteca multimedia

PUID=1000
PGID=1000
TZ=Europe/Madrid

JELLYFIN_IMAGE=lscr.io/linuxserver/jellyfin@sha256:234ea8d508b2cba26054d0dac9d4c0353435dce483e8b266947d473629774559
JELLYFIN_CONTAINER_NAME=jellyfin-lab
JELLYFIN_BIND_IP=127.0.0.1
JELLYFIN_BIND_PORT=8097

JELLYFIN_CONFIG_PATH=/mnt/dr-lab-jellyfin-root-replica-20260410-033003/services/jellyfin/config
JELLYFIN_CUSTOM_INIT_PATH=/mnt/dr-lab-jellyfin-root-replica-20260410-033003/services/jellyfin/custom-cont-init.d
JELLYFIN_MEDIA_PATH=/mnt/dr-lab-jellyfin-media-replica-20260410-033003

JELLYFIN_CACHE_PATH=/var/tmp/jellyfin-lab/cache
JELLYFIN_TRANSCODE_PATH=/var/tmp/jellyfin-lab/transcode
