#!/usr/bin/env bash
set -Eeuo pipefail

usage() {
  cat <<'USAGE'
Uso:
  zfs-restore-backup1-dataset --ssh-target HOST --dataset DATASET --tag TAG --dest DESTINO [--dry-run]

Ejemplo:
  zfs-restore-backup1-dataset \
    --ssh-target backup1-dr \
    --dataset nextcloud/config \
    --tag replica-20260410-033003 \
    --dest ~/dr-tests/restore-nextcloud-config
USAGE
}

SSH_TARGET=""
DATASET=""
TAG=""
DEST=""
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --ssh-target) SSH_TARGET="${2:-}"; shift 2 ;;
    --dataset)    DATASET="${2:-}"; shift 2 ;;
    --tag)        TAG="${2:-}"; shift 2 ;;
    --dest)       DEST="${2:-}"; shift 2 ;;
    --dry-run)    DRY_RUN=1; shift ;;
    -h|--help)    usage; exit 0 ;;
    *) echo "Argumento no reconocido: $1" >&2; usage >&2; exit 2 ;;
  esac
done

[[ -n "$SSH_TARGET" ]] || { echo "Falta --ssh-target" >&2; exit 2; }
[[ -n "$DATASET"    ]] || { echo "Falta --dataset" >&2; exit 2; }
[[ -n "$TAG"        ]] || { echo "Falta --tag" >&2; exit 2; }
[[ -n "$DEST"       ]] || { echo "Falta --dest" >&2; exit 2; }

[[ "$DATASET" != /* ]] || { echo "--dataset no debe empezar por /" >&2; exit 2; }
[[ "$DEST" != "/"  ]] || { echo "--dest no puede ser /" >&2; exit 2; }

DEST="${DEST%/}"
[[ -n "$DEST" ]] || { echo "--dest no puede quedar vacío" >&2; exit 2; }

STAMP="$(date +%Y%m%d-%H%M%S)"
SAFE_DATASET="${DATASET//\//-}"

REMOTE_DATASET="backup/replicas/main1/tank/${DATASET}"
REMOTE_SNAPSHOT="${REMOTE_DATASET}@${TAG}"
REMOTE_CLONE="backup/restore-tests/${SAFE_DATASET}-${STAMP}"
REMOTE_MOUNT="/mnt/restore-test-${SAFE_DATASET}-${STAMP}"
LOCAL_TARGET_DIR="${DEST}/${SAFE_DATASET}"

SSH_OPTS=(
  -o ControlMaster=auto
  -o ControlPersist=600
  -o ControlPath=/tmp/ssh-zfs-restore-%C
)

REMOTE_READY=0

cleanup_remote() {
  if (( REMOTE_READY == 1 )); then
    echo
    echo "[cleanup] Intentando limpiar temporales remotos..."
    ssh "${SSH_OPTS[@]}" "$SSH_TARGET" \
      "sudo -n /usr/local/sbin/backup1-zfs-restore-helper cleanup '${REMOTE_CLONE}' '/tmp/no-file-needed'" || true
  fi
}

cleanup_ssh_master() {
  ssh "${SSH_OPTS[@]}" -O exit "$SSH_TARGET" >/dev/null 2>&1 || true
}

cleanup_all() {
  cleanup_remote
  cleanup_ssh_master
}

trap cleanup_all EXIT

echo "zfs-restore-backup1-dataset (plan)"
echo "DRY_RUN=$DRY_RUN"
echo "SSH_TARGET=$SSH_TARGET"
echo "REMOTE_DATASET=$REMOTE_DATASET"
echo "REMOTE_SNAPSHOT=$REMOTE_SNAPSHOT"
echo "REMOTE_CLONE=$REMOTE_CLONE"
echo "REMOTE_MOUNT=$REMOTE_MOUNT"
echo "LOCAL_TARGET_DIR=$LOCAL_TARGET_DIR"

echo
echo "[check] Comprobando snapshot remoto..."
ssh "${SSH_OPTS[@]}" "$SSH_TARGET" \
  "sudo -n /usr/local/sbin/backup1-zfs-restore-helper snapshot-exists '$REMOTE_SNAPSHOT'"

if [[ "$DRY_RUN" -eq 1 ]]; then
  exit 0
fi

echo
echo "[run] Creando clone remoto..."
ssh "${SSH_OPTS[@]}" "$SSH_TARGET" \
  "sudo -n /usr/local/sbin/backup1-zfs-restore-helper clone-mount '${REMOTE_SNAPSHOT}' '${REMOTE_CLONE}' '${REMOTE_MOUNT}'"
REMOTE_READY=1

echo
echo "[run] Recreando directorio destino local..."
mkdir -p "$DEST"
if [[ -e "$LOCAL_TARGET_DIR" ]]; then
  if rm -rf -- "$LOCAL_TARGET_DIR" 2>/dev/null; then
    :
  else
    sudo -n rm -rf -- "$LOCAL_TARGET_DIR"
  fi
fi
mkdir -p "$LOCAL_TARGET_DIR"

echo
echo "[run] Extrayendo dataset por streaming (sin tar local)..."
ssh "${SSH_OPTS[@]}" "$SSH_TARGET" \
  "sudo -n /usr/local/sbin/backup1-zfs-restore-helper tar-stdout '${REMOTE_MOUNT}' '.'" \
  | tar -C "$LOCAL_TARGET_DIR" -xf -

find "$LOCAL_TARGET_DIR" -maxdepth 2 | sed -n '1,60p'

echo
echo "[run] Limpiando temporales remotos..."
ssh "${SSH_OPTS[@]}" "$SSH_TARGET" \
  "sudo -n /usr/local/sbin/backup1-zfs-restore-helper cleanup '${REMOTE_CLONE}' '/tmp/no-file-needed'"
REMOTE_READY=0

cleanup_ssh_master
trap - EXIT

echo
echo "Restore dataset completado."
echo "LOCAL_TARGET_DIR=$LOCAL_TARGET_DIR"
