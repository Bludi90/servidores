#!/usr/bin/env bash
set -Eeuo pipefail

LOG="/home/alejandro/servidores/state/main1/zfs-repl-backup1-nightly.log"
RUNS_FILE="/home/alejandro/servidores/state/main1/zfs-repl-backup1-runs.tsv"
STATE_FILE="/home/alejandro/servidores/state/main1/zfs-repl-backup1.last_common"

HOST_WOL="sv-backup1"
HOST_IP="192.168.1.122"
HOST_SSH="backup1"
SSH_LOCAL_USER="alejandro"

REPL_CMD="/usr/local/bin/zfs-repl-backup1"
REMOTE_POWEROFF_CHECK="sudo -n /usr/local/sbin/backup1-safe-poweroff --check"
REMOTE_POWEROFF_REAL="sudo -n /usr/local/sbin/backup1-safe-poweroff"

LOCK_FILE="/var/lock/zfs-repl-backup1-nightly.lock"

PING_WAIT_UP=300
SSH_WAIT_UP=300
DOWN_WAIT=180
POST_DOWN_GRACE=30
WOL_RETRIES=3
WOL_RETRY_SLEEP=10

START_EPOCH="$(date +%s)"
START_ISO="$(date -Iseconds)"

MODE="unknown"
PHASE="init"
RESULT="FAIL"
NOTE=""
HOST_STARTED="no"
WAKE_OK="no"
REPL_OK="no"
SHUTDOWN_OK="no"
BASE_COMMON_PRE=""
BASE_COMMON_POST=""

ts() { date '+%F %T'; }
log() { echo "[$(ts)] $*" | tee -a "$LOG" ; }

usage() {
  cat <<'USAGE'
Uso:
  zfs-repl-backup1-nightly --check
  zfs-repl-backup1-nightly
USAGE
}

ssh_run() {
  sudo -u "$SSH_LOCAL_USER" -H ssh -o BatchMode=yes -o ConnectTimeout=3 "$HOST_SSH" "$@"
}

ping_ok() {
  ping -c 1 -W 1 "$HOST_IP" >/dev/null 2>&1
}

ssh_ok() {
  ssh_run 'echo ok' >/dev/null 2>&1
}

read_base_common() {
  [[ -r "$STATE_FILE" ]] && cat "$STATE_FILE" || true
}

ensure_runs_file() {
  mkdir -p "$(dirname "$RUNS_FILE")"
  if [[ ! -e "$RUNS_FILE" ]]; then
    awk 'BEGIN{
      OFS="	";
      print "start_iso","end_iso","mode","rc","result","phase","host_started","wake_ok","repl_ok","shutdown_ok","base_common_pre","base_common_post","duration_s","note"
    }' > "$RUNS_FILE"
  fi
}

sanitize_tsv() {
  local s="${1-}"
  s="${s//$'\t'/ }"
  s="${s//$'\n'/ }"
  printf '%s' "$s"
}

append_run_record() {
  local rc="$1"
  local end_epoch end_iso duration

  end_epoch="$(date +%s)"
  end_iso="$(date -Iseconds)"
  duration=$(( end_epoch - START_EPOCH ))

  ensure_runs_file

  awk \
    -v a="$START_ISO" \
    -v b="$end_iso" \
    -v c="$MODE" \
    -v d="$rc" \
    -v e="$RESULT" \
    -v f="$PHASE" \
    -v g="$HOST_STARTED" \
    -v h="$WAKE_OK" \
    -v i="$REPL_OK" \
    -v j="$SHUTDOWN_OK" \
    -v k="$(sanitize_tsv "$BASE_COMMON_PRE")" \
    -v l="$(sanitize_tsv "$BASE_COMMON_POST")" \
    -v m="$duration" \
    -v n="$(sanitize_tsv "$NOTE")" \
    'BEGIN{
      OFS="	";
      print a,b,c,d,e,f,g,h,i,j,k,l,m,n
    }' >> "$RUNS_FILE"
}

on_exit() {
  local rc=$?

  case "$MODE" in
    check|real)
      if [[ "$RESULT" != "OK" && "$RESULT" != "LOCKED" ]]; then
        RESULT="FAIL"
      fi
      append_run_record "$rc"
      ;;
    *)
      ;;
  esac
}
trap on_exit EXIT

wait_until_down() {
  local timeout="$1" elapsed=0
  while (( elapsed < timeout )); do
    if ! ping_ok && ! ssh_ok; then
      return 0
    fi
    sleep 2
    elapsed=$((elapsed + 2))
  done
  return 1
}

wait_for_ping_up() {
  local timeout="$1" elapsed=0
  while (( elapsed < timeout )); do
    if ping_ok; then
      return 0
    fi
    sleep 2
    elapsed=$((elapsed + 2))
  done
  return 1
}

wait_for_ssh_up() {
  local timeout="$1" elapsed=0
  while (( elapsed < timeout )); do
    if ssh_ok; then
      return 0
    fi
    sleep 2
    elapsed=$((elapsed + 2))
  done
  return 1
}

run_common_checks() {
  PHASE="check-common"
  log "INFO  check: iniciando comprobaciones comunes"

  command -v wol >/dev/null
  log "OK    check: comando wol encontrado"

  command -v wolctl >/dev/null
  log "OK    check: comando wolctl encontrado"

  test -x "$REPL_CMD"
  log "OK    check: comando de réplica encontrado: $REPL_CMD"

  sudo wolctl show "$HOST_WOL" >/dev/null
  log "OK    check: host WOL registrado: $HOST_WOL"
}

run_online_checks() {
  PHASE="check-online"
  log "INFO  check: iniciando comprobaciones online"

  if ping_ok; then
    log "OK    check: ping a $HOST_IP responde"
  else
    log "ERROR check: ping a $HOST_IP no responde"
    NOTE="ping no responde"
    return 1
  fi

  if ssh_ok; then
    log "OK    check: SSH a $HOST_SSH responde"
  else
    log "ERROR check: SSH a $HOST_SSH no responde"
    NOTE="ssh no responde"
    return 1
  fi

  ssh_run "$REMOTE_POWEROFF_CHECK" >/dev/null
  log "OK    check: poweroff remoto no interactivo validado"

  log "INFO  check: comprobaciones online OK"
}

run_checks() {
  BASE_COMMON_PRE="$(read_base_common)"
  BASE_COMMON_POST="$BASE_COMMON_PRE"

  run_common_checks
  run_online_checks

  PHASE="done"
  RESULT="OK"
  NOTE="check-ok"
  log "INFO  check: todas las comprobaciones críticas pasaron"
}

wake_host() {
  local i
  PHASE="wake"
  log "INFO  wake: enviando magic packet a $HOST_WOL"

  for ((i=1; i<=WOL_RETRIES; i++)); do
    sudo wol "$HOST_WOL" >/dev/null
    log "INFO  wake: intento $i/$WOL_RETRIES enviado"
    if (( i < WOL_RETRIES )); then
      sleep "$WOL_RETRY_SLEEP"
    fi
  done

  log "INFO  wake: esperando ping hasta ${PING_WAIT_UP}s"
  wait_for_ping_up "$PING_WAIT_UP"
  log "OK    wake: ping recuperado"

  log "INFO  wake: esperando SSH hasta ${SSH_WAIT_UP}s"
  wait_for_ssh_up "$SSH_WAIT_UP"
  log "OK    wake: SSH recuperado"

  WAKE_OK="yes"
}

shutdown_host() {
  PHASE="shutdown"
  log "INFO  shutdown: ordenando apagado remoto"
  ssh_run "$REMOTE_POWEROFF_REAL" >/dev/null || true

  log "INFO  shutdown: esperando caída completa hasta ${DOWN_WAIT}s"
  wait_until_down "$DOWN_WAIT"
  log "OK    shutdown: host apagado"

  SHUTDOWN_OK="yes"

  log "INFO  shutdown: margen post-apagado ${POST_DOWN_GRACE}s"
  sleep "$POST_DOWN_GRACE"

  log "INFO  shutdown: fin del ciclo"
}

run_real() {
  local started_by_wrapper=0

  BASE_COMMON_PRE="$(read_base_common)"

  run_common_checks

  if ping_ok || ssh_ok; then
    log "INFO  main: $HOST_WOL ya estaba encendido; no se enviará WOL"
    started_by_wrapper=0
    HOST_STARTED="no"
  else
    log "INFO  main: $HOST_WOL estaba apagado; se iniciará por WOL"
    started_by_wrapper=1
    HOST_STARTED="yes"
    wake_host
  fi

  run_online_checks

  PHASE="repl"
  log "INFO  repl: lanzando réplica real"
  "$REPL_CMD" --yes
  REPL_OK="yes"
  BASE_COMMON_POST="$(read_base_common)"
  log "OK    repl: réplica finalizada"

  if (( started_by_wrapper == 1 )); then
    log "INFO  main: el host fue encendido por este wrapper; se apagará al final"
    shutdown_host
  else
    log "INFO  main: el host ya estaba encendido al inicio; se deja encendido"
    SHUTDOWN_OK="no"
  fi

  PHASE="done"
  RESULT="OK"
  NOTE="real-ok"
  log "INFO  main: flujo completado correctamente"
}

main() {
  case "${1-}" in
    --check)
      MODE="check"
      ;;
    "")
      MODE="real"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac

  exec 9> "$LOCK_FILE"
  if ! flock -n 9; then
    RESULT="LOCKED"
    PHASE="lock"
    NOTE="otra ejecución en curso"
    log "WARN  lock: otra ejecución de zfs-repl-backup1-nightly ya está en curso"
    exit 1
  fi

  case "$MODE" in
    check)
      run_checks
      ;;
    real)
      run_real
      ;;
  esac
}

main "${1-}"
