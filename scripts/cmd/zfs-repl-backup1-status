#!/usr/bin/env bash
set -Eeuo pipefail

RUNS_FILE="/home/alejandro/servidores/state/main1/zfs-repl-backup1-runs.tsv"
WINDOW_DAYS="${1:-7}"
EXPECTED_PER_WEEK=7

fmt_short_date() {
  local iso="$1"
  local dow num
  num="$(date -d "$iso" +%u)"
  case "$num" in
    1) dow="L" ;;
    2) dow="M" ;;
    3) dow="X" ;;
    4) dow="J" ;;
    5) dow="V" ;;
    6) dow="S" ;;
    7) dow="D" ;;
    *) dow="?" ;;
  esac
  printf '%s:%s' "$dow" "$(date -d "$iso" +%d/%m/%y)"
}

if [[ ! -f "$RUNS_FILE" ]]; then
  echo "Snpsht FAIL (OK=0/7, FAIL=0, MISS=7, últ OK: ---)"
  exit 2
fi

cutoff_epoch="$(date -d "-${WINDOW_DAYS} days" +%s)"

ok_count=0
fail_count=0
total_real=0
last_ok_iso=""

while IFS=$'\t' read -r start_iso end_iso mode rc result phase host_started wake_ok repl_ok shutdown_ok base_common_pre base_common_post duration_s note; do
  [[ "$start_iso" == "start_iso" ]] && continue
  [[ "$mode" != "real" ]] && continue

  row_epoch="$(date -d "$start_iso" +%s 2>/dev/null || echo 0)"
  (( row_epoch < cutoff_epoch )) && continue

  total_real=$((total_real + 1))

  if [[ "$result" == "OK" ]]; then
    ok_count=$((ok_count + 1))
    if [[ -z "$last_ok_iso" ]] || [[ "$(date -d "$start_iso" +%s)" -gt "$(date -d "$last_ok_iso" +%s)" ]]; then
      last_ok_iso="$start_iso"
    fi
  else
    fail_count=$((fail_count + 1))
  fi
done < "$RUNS_FILE"

miss_count=$((EXPECTED_PER_WEEK - total_real))
(( miss_count < 0 )) && miss_count=0

if (( ok_count >= EXPECTED_PER_WEEK )); then
  status="OK"
  exit_code=0
elif (( ok_count >= 1 )); then
  status="WARN"
  exit_code=1
else
  status="FAIL"
  exit_code=2
fi

if [[ -n "$last_ok_iso" ]]; then
  last_ok_fmt="$(fmt_short_date "$last_ok_iso")"
else
  last_ok_fmt="---"
fi

echo "Snpsht ${status} (OK=${ok_count}/${EXPECTED_PER_WEEK}, FAIL=${fail_count}, MISS=${miss_count}, últ OK: ${last_ok_fmt})"
exit "$exit_code"
