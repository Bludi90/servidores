# --- NUNCA subir secretos ---
# Claves / cifrados
id_* 
*.key
*.pem
*.p12
*.pfx
*.kdbx
*.gpg
*.age
*.asc
*.enc

# Passwords / tokens / vaults / env
*.token
*.secret*
*password*
*.pass
*.vault
*.secrets
.env
.env.*

# Configs reales (permitimos solo ejemplos)
*.ovpn
wg*.conf
*wireguard*.conf
ssh_config
known_hosts
authorized_keys
*.conf
!*.conf.sample
!*.conf.example

# Logs crudos (exportaremos resúmenes sanitizados a state/)
raw_logs/
private/

# Ruido del sistema / editores
.DS_Store
Thumbs.db
*.swp
*~
scripts/*.bak*
*.bak
scripts/root/
scripts/root/

# Estado horario local: publicar solo la foto actual en main
state/*/*-state.md
state/backup1/backup1-state-*.md
!state/*/current-state.md

# Logs y locks locales
state/*/sync.log
state/*/cron.out
state/*/.state-hourly.lock
state/*/cron-zfs-repl-backup1-nightly.out

# Informes históricos locales
reports/daily/
